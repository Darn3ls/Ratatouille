<div class="col">
    <div class="card h-100">
        <div class="ratio ratio-1x1">
            <img src="@recipe.ImmagineUrl" class="card-img-top" style="object-fit: cover;" alt="@recipe.Titolo" />
        </div>
        <div class="card-body">
            <h5 class="card-title">@recipe.Titolo</h5>
            <p class="card-text">
                @recipe.DescrizioneBreve
            </p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Recipe recipe { get; set; }
}
